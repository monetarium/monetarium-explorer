{{define "html-head"}}
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	{{/* The above meta tags *must* come first in the head */ -}}
	{{- if .Data.Host -}}
	<meta name="description" content="Monetarium Block Explorer">
	<meta name="author" content="The Monetarium developers">
	<meta name="application-name"           content="Monetarium Block Explorer">
	<meta name="apple-mobile-web-app-title" content="Monetarium Block Explorer">

	<meta name="twitter:card" content="summary"/>
	<meta name="twitter:title" content="Monetarium Block Explorer"/>
	<meta name="twitter:description" content="{{ .Title }}"/>
	<meta name="twitter:image" content="{{ .Data.BaseURL }}/images/monetarium400x348.png?v=2"/>

	<meta property="og:site_name"   content="monetarium-explorer" />
	<meta property="og:title"       content="Monetarium Block Explorer" />
	<meta property="og:description" content="{{ .Title }}" />
	<meta property="og:type"        content="website" />
	<meta property="og:url"         content="{{ .Data.CanonicalURL }}" />
	<meta property="og:image"       content="{{ .Data.BaseURL }}/images/monetarium400x348.png?v=2" />
	{{- end}}

	{{- if ne .Data.Links.OnionURL "" }}
	<meta http-equiv="onion-location" content="http://{{.Data.Links.OnionURL}}" />
	{{ end }}

	<!-- Favicon -->
	<link rel="icon" href="/images/favicon/favicon.ico?v=20260428" sizes="48x48">
	<link rel="icon" type="image/png" href="/images/favicon/favicon-96x96.png?v=20260428" sizes="96x96">
	<link rel="icon" type="image/svg+xml" href="/images/favicon/favicon.svg?v=20260428">
	<link rel="apple-touch-icon" sizes="180x180" href="/images/favicon/apple-touch-icon.png?v=20260428">
	<meta name="theme-color" content="{{ if .Data.Cookies.DarkMode }}#292929{{ else if eq theme "theme-testnet" }}#1d331a{{ else if eq theme "theme-simnet" }}#076191{{ else }}#ffffff{{ end }}">
	<link rel="manifest" href="/images/favicon/site.webmanifest?v=20260428">
  <!-- End favicon -->

	<meta name="turbo-cache-control" content="no-cache">
	<title>{{.Title}}</title>

	{{/* Preload the above-the-fold web fonts so text (including the LCP element)
	     is not blocked waiting for the stylesheet to be parsed first. The
	     crossorigin attribute is required for font preloads even same-origin,
	     because fonts are fetched in CORS mode. */ -}}
	<link rel="preload" href="/fonts/source-sans-pro-v9-latin-regular.woff2" as="font" type="font/woff2" crossorigin>
	<link rel="preload" href="/fonts/source-sans-pro-semibold.woff2" as="font" type="font/woff2" crossorigin>

	<link href="{{asset "app.css"}}" rel="stylesheet">

</head>
{{end}}

{{define "navbar"}}
<body class="{{ theme }}{{if .Cookies.DarkMode}} darkBG{{end}}" data-theme-color="{{ if eq theme "theme-testnet" }}#1d331a{{ else if eq theme "theme-simnet" }}#076191{{ else }}#ffffff{{ end }}">
<header class="top-nav d-flex align-items-center" id="navBar" data-blocktime="{{.BlockTimeUnix}}">
	<div class="container d-flex justify-content-between align-items-center">
		<a class="no-underline d-block home-link monetarium-logo" href="/"></a>
		<form
			class="search-form"
			role="search"
			id="search-form"
			action="/search"
			data-controller="search"
			data-action="submit->search#execute"
		>
			<input
				tabindex="0"
				type="text"
				name="search"
				id="search"
				class="top-search mousetrap"
				placeholder="Search for blocks, addresses, transactions or proposal tokens"
				spellcheck="false"
				autocomplete="off"
			/>
			<button class="search-bttn" type="submit"><span class="monicon-search"></span></button>
		</form>
		<nav id="hamburger-menu" data-controller="menu" data-turbo-permanent>
			<div id="menu-toggle">
				<input type="checkbox" name="menu-toggle" aria-label="Toggle navigation menu" data-menu-target="toggle" data-action="change->menu#toggle"/>
				<span class="patty"></span>
				<span class="patty"></span>
				<span class="patty short"></span>
				<div id="menu">
					<a class="menu-item" data-keynav-skip href="/" title="Home">Home</a>
					<a class="menu-item" data-keynav-skip href="/blocks" title="Monetarium blocks">Blocks</a>
					<a class="menu-item" data-keynav-skip href="/visualblocks" title="Monetarium Visual Blocks">Visual Blocks</a>
					<a class="menu-item" data-keynav-skip href="/mempool" title="Monetarium mempool">Mempool</a>
					<a class="menu-item" data-keynav-skip href="/ticketpool" title="Monetarium ticket pool">Ticket Pool</a>
					<a class="menu-item jsonly" data-keynav-skip href="/charts" title="Monetarium charts">Charts</a>
					<a class="menu-item" data-keynav-skip href="/agendas" title="Consensus Deployment Agendas">Agendas</a>
					<a class="menu-item" data-keynav-skip href="/attack-cost" title="Monetarium Attack Cost">Attack Cost</a>
					<a class="menu-item" data-keynav-skip href="/parameters" title="Chain Parameters">Parameters</a>
					<a class="menu-item" data-keynav-skip href="/decodetx" title="Decode or send a raw transaction">Decode/Broadcast Tx</a>
					<a class="menu-item" data-keynav-skip href="/verify-message" title="Verify Message">Verify Message</a>
				{{- if eq .NetName "Mainnet"}}
					<a class="menu-item" data-keynav-skip href="{{.Links.Testnet}}" title="Home">Switch To Testnet</a>
				{{- else}}
					<a class="menu-item" data-keynav-skip href="{{.Links.Mainnet}}" title="Home">Switch To Mainnet</a>
				{{- end}}
					<form action="/set" method="post" data-menu-target="form" class="menu-form">
						<input type="hidden" name="darkmode" value="darkmode">
						<input type="hidden" name="requestURI" value="{{.RequestURI}}">
						<button type="submit" data-action="click->menu#onSunClick"
								class="menu-submit text-start w-100 p-0"
								data-keynav-skip>
								<div class="menu-item">
								  <span id="sun-icon" class="monicon-sun-fill no-underline pe-2"></span>
								  Night Mode
								</div>
						</button>
					</form>
					<a class="menu-item jsonly" data-keynav-skip data-turbo="false" href="#" id="keynav-toggle">
						<span class="text">Enable Hot Keys</span><span class="keys-hint">(&nbsp;&nbsp;<span class="arrows"> &#8592;<br>&#8594;</span>&nbsp;&nbsp;enter&nbsp;&nbsp;\&nbsp;&nbsp;=&nbsp;&nbsp;)</span>
					</a>
					<a class="menu-item" data-keynav-skip href="{{.Links.APIDocs}}" title="API Endpoints" target="_blank" rel="noopener noreferrer">JSON API Docs</a>
				</div>
			</div>
		</nav>
	</div>
</header>
{{end}}

{{define "footer"}}
<footer class="navbar-fixed-bottom">
	<div class="container d-flex justify-content-between align-items-center">
		<span>
			<span data-controller="time" data-time-target="blocktime" data-stamp="{{$.Tip.Time}}"></span> <span class="d-none d-sm-inline">since last block</span>
		</span>
		<span>
			<a
				class="text-nowrap d-none d-md-inline-block pe-3"
				href="{{.Links.Github}}"
				title="monetarium-explorer on GitHub"
				target="_blank"
				rel="noopener noreferrer"
			>monetarium-explorer v{{.Version}}</a>
			{{- if ne .Links.OnionURL "" }}
			<a
				class="text-nowrap d-none d-md-inline-block pe-3"
				href="{{.Links.OnionURL}}"
				title="Access monetarium-explorer over Tor"
				target="_blank"
				rel="noopener noreferrer"
			>Tor site</a>
			{{ end }}
			<a
				class="text-nowrap"
				href="{{.Links.License}}"
				target="_blank"
				rel="noopener noreferrer"
			>© {{currentYear}} The Monetarium developers (ISC)</a>
		</span>
		<span
			id="connection"
			class="text-nowrap align-items-center clickable d-inline-block"
			data-turbo-permanent
			data-controller="connection"
			data-connection-target="indicator"
			data-action="click->connection#requestNotifyPermission"
			title="While connected, you will receive live page updates and, if enabled, desktop notifications (click to enable)."
			><span class="d-none d-sm-inline" data-connection-target="status">Connecting <span class="d-none d-md-inline-block">to WebSocket...</span></span><div></div>
		</span>
	</div>
	<script
		src="{{asset "js/4.bundle.js"}}"
		data-turbo-eval="false"
		defer
	></script>
	<script
		src="{{asset "app.js"}}"
		data-turbo-eval="false"
		defer
	></script>
</footer>
{{end}}

{{define "decimalParts" -}}
{{- $int := index . 0 -}}
{{- if eq (len .) 4 -}}
{{- $bold := index . 1 -}}
{{- $rest := index . 2 -}}
{{- $trail := index . 3 -}}
<div class="decimal-parts d-inline-block"><span class="int">{{- if gt (len $bold) 0 -}}{{$int}}.{{$bold}}{{- else -}}{{$int}}{{- end -}}</span><span class="decimal">{{$rest}}</span><span class="decimal trailing-zeroes">{{$trail}}</span></div>
{{- else -}}
{{- $dec := index . 1 -}}
{{- $trail := index . 2 -}}
<div class="decimal-parts d-inline-block"><span class="int">{{$int}}</span>{{- if or (gt (len $dec) 0) (gt (len $trail) 0) -}}<span class="decimal dot">.</span>{{- end -}}<span class="decimal">{{$dec}}</span><span class="decimal trailing-zeroes">{{$trail}}</span></div>
{{- end -}}
{{- end}}

{{define "fmtPercentage"}}
  {{- if gt . 0.0 -}}
    <span class="text-green">+{{printf "%.2f" .}} %</span>
  {{- else -}}
    <span class="text-danger">{{printf "%.2f" .}} %</span>
  {{- end -}}
{{end}}

{{define "hashElide"}}
  {{- $hash := (index . 0) -}}
  {{- $link := (index . 1) -}}
  {{- if eq $link "" -}}
	<div
  {{- else -}}
	<a href="{{$link}}"
  {{- end}} data-keynav-priority class="elidedhash mono" data-head="{{hashStart $hash}}" data-tail="{{hashEnd $hash}}">
  {{- $hash}}
  {{- if eq $link ""}}</div>{{else}}</a>{{template "copyTextIcon"}}{{end -}}
{{end}}

{{define "addressTable"}}
{{- $txType := .TxnType}}
{{- if .Transactions}}
<table class="table table-mono-cells table-responsive-sm">
	<thead>
		<tr>
		<th class="d-none d-sm-table-cell">Tx Type</th>
		<th class="text-start">Input/&#8203;Output ID</th>
		<th class="text-start">Coin</th>
	{{- if eq $txType "merged_debit"}}
		<th class="text-end"><span class="d-sm-none position-relative" data-tooltip="merged input count">Cnt</span
			><span class="d-none d-sm-inline">Inputs</span>
		</th>
		<th class="text-end">Debit</th>
	{{- else if eq $txType "merged_credit" }}
		<th class="text-end"><span class="d-sm-none position-relative" data-tooltip="merged output count">Cnt</span
			><span class="d-none d-sm-inline">Outputs</span>
		</th>
		<th class="text-end">Credit</th>
	{{- else if eq $txType "merged" }}
		<th title="Count of address's inputs and outputs in the transaction." class="text-end"><span class="d-none d-sm-inline-block">I/O Count</span><span class="d-sm-none position-relative" data-tooltip="# of inputs and outputs">#</span></th>
		<th class="text-end">Credit</th>
		<th class="text-end">Debit</th>
	{{- else if eq $txType "unspent" }}
		<th class="text-end">Credit</th>
	{{- else}}
		<th class="text-end">Credit</th>
		<th class="text-end">Debit</th>
	{{- end}}
		<th class="d-none d-sm-table-cell text-end">Time (UTC)</th>
		<th class="text-end">Age</th>
		<th class="text-end"><span class="d-sm-none position-relative" data-tooltip="Confirmations">Cons</span><span class="d-none d-sm-inline">Confirms</span></th>
		<th class="d-none d-sm-table-cell text-end">Size</th>
		</tr>
	</thead>
	<tbody>
	{{- range .Transactions}}
		<tr{{if eq .Confirmations 0}} data-address-target="pending" data-txid="{{.TxID}}"{{end}}>
			<td class="d-none d-sm-table-cell">{{.TxType}}</td>
			<td class="clipboard">{{template "hashElide" (hashlink .TxID .Link)}}</td>
			<td data-coin-type="{{.CoinType}}">{{coinSymbol .CoinType}}</td>
		{{- if eq $txType "merged_debit"}}
			<td class="text-end">{{.MergedTxnCount}}</td>
			<td class="text-end fs15">{{if eq .CoinType 0}}{{template "decimalParts" (float64AsDecimalParts .SentTotal 8 false)}}{{else}}{{template "decimalParts" (skaDecimalParts .SKAValue true)}}{{end}}</td>
		{{- else if eq $txType "merged_credit"}}
			<td class="text-end">{{.MergedTxnCount}}</td>
			<td class="text-end fs15">{{if eq .CoinType 0}}{{template "decimalParts" (float64AsDecimalParts .ReceivedTotal 8 false)}}{{else}}{{template "decimalParts" (skaDecimalParts .SKAValue true)}}{{end}}</td>
		{{- else if eq $txType "merged"}}
			<td class="text-end">{{.MergedTxnCount}}</td>
			{{- if .IsFunding}}
			<td class="text-end fs15">{{if eq .CoinType 0}}{{template "decimalParts" (float64AsDecimalParts .ReceivedTotal 8 false)}}{{else}}{{template "decimalParts" (skaDecimalParts .SKAValue true)}}{{end}}</td>
			<td class="text-end">&mdash;</td>
			{{- else}}
			<td class="text-end">&mdash;</td>
			<td class="text-end fs15">{{if eq .CoinType 0}}{{template "decimalParts" (float64AsDecimalParts .SentTotal 8 false)}}{{else}}{{template "decimalParts" (skaDecimalParts .SKAValue true)}}{{end}}</td>
			{{- end}}
		{{- else if eq $txType "unspent"}}
			<td class="text-end fs15">{{if eq .CoinType 0}}{{template "decimalParts" (float64AsDecimalParts .ReceivedTotal 8 false)}}{{else}}{{template "decimalParts" (skaDecimalParts .SKAValue true)}}{{end}}</td>
		{{- else if or (eq $txType "credit") .IsFunding}}{{/* .IsFunding = true && txType = "all" is a credit */}}
			<td class="text-end fs15">{{if eq .CoinType 0}}{{template "decimalParts" (float64AsDecimalParts .ReceivedTotal 8 false)}}{{else}}{{template "decimalParts" (skaDecimalParts .SKAValue true)}}{{end}}</td>
			{{- if .MatchedTx}}
			<td class="text-end"><a href="/tx/{{.MatchedTx}}/in/{{.MatchedTxIndex}}"
				data-txid="{{.MatchedTx}}"
				data-action="mouseover->address#hashOver mouseout->address#hashOut"
				>spent</a></td>
			{{- else}}
			<td class="text-end">unspent</td>
			{{- end}}
		{{- else}}{{/* either "debit", or "all" with .IsFunding = false */ -}}
			{{- if and (eq .CoinType 0) (eq .SentTotal 0.0)}}
			<td class="text-end">sstxcommitment</td>
			{{- else if .MatchedTx }}
			<td class="text-end"><a href="/tx/{{.MatchedTx}}/out/{{.MatchedTxIndex}}" data-action="mouseover->address#hashOver mouseout->address#hashOut">source</a></td>
			{{- else}}
			<td class="text-end">N/A</td>
			{{- end}}
			<td class="text-end fs15">{{if eq .CoinType 0}}{{template "decimalParts" (float64AsDecimalParts .SentTotal 8 false)}}{{else}}{{template "decimalParts" (skaDecimalParts .SKAValue true)}}{{end}}</td>
		{{- end}}
			<td class="addr-tx-time d-none d-sm-table-cell text-end">{{if eq .Confirmations 0}}Unconfirmed{{else}}{{.Time.DatetimeWithoutTZ}}{{end}}</td>
			<td class="addr-tx-age text-end">
			{{- if eq (.Time.T.Unix) 0}}
				N/A
			{{- else}}
				<span data-controller="time" data-time-target="age" data-age="{{.Time.UNIX}}"></span>
			{{- end}}
			</td>
			<td class="addr-tx-confirms text-end"	{{/*Update confirmations with Stimulus*/ -}}
				data-newblock-target="confirmations" {{/*trim*/ -}}
				data-confirmations="{{.Confirmations}}" {{/*trim*/ -}}
				data-confirmation-block-height="{{if eq .Confirmations 0}}-1{{else}}{{.BlockHeight}}{{end}}" {{/*trim*/ -}}
				data-yes="#" {{/*trim*/ -}}
				data-no="(unconfirmed)" {{/*trim*/ -}}
			>{{.Confirmations}}</td>
			<td class="text-end d-none d-sm-table-cell text-end">{{.FormattedSize}}</td>
		</tr>
	{{- end}}
	</tbody>
</table>
{{- else}}
<table class="table table-mono-cells">
	<tr>
		<td>
			No "{{$txType}}" transactions found for this address.
		</td>
	</tr>
</table>
{{- end}}
{{- end}}

{{define "mempoolDump"}}
  {{$likely := .LikelyMineable}}
  data-id="{{.Ident}}"
  data-total="{{$likely.Total}}"
  data-size="{{$likely.Size}}"
  data-count="{{$likely.Count}}"
  data-reg-total="{{$likely.RegularTotal}}"
  data-reg-count="{{.NumRegular}}"
  data-vote-total="{{$likely.VoteTotal}}"
  data-vote-count="{{.VotingInfo.TicketsVoted}}"
  data-ticket-total="{{$likely.TicketTotal}}"
  data-ticket-count="{{.NumTickets}}"
  data-rev-total="{{$likely.RevokeTotal}}"
  data-rev-count="{{.NumRevokes}}"
{{end}}

