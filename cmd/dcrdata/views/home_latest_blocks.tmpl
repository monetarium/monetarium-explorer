{{define "home_latest_blocks"}}
  <table class="table w-100 mt-2 mx-auto mb-0 latest-blocks-table">
    <thead>
      <tr>
        <th class="text-start ps-2 position-relative" data-tooltip="block height">Height</th>
        <th class="text-end position-relative" data-tooltip="number of transactions">
          <span class="d-md-none">Txns</span>
          <span class="d-none d-md-inline">Transactions</span>
        </th>
        <th class="text-end position-relative" data-tooltip="total VAR amount">VAR</th>
        <th class="text-end position-relative" data-tooltip="total SKA amount">SKA</th>
        <th class="text-end d-none d-sm-table-cell d-md-none d-lg-table-cell position-relative" data-tooltip="total block size">Size</th>
        <th class="text-end position-relative" data-tooltip="tickets voted">
          <span class="d-sm-none">Vote</span>
          <span class="d-none d-sm-inline">Votes</span>
        </th>
        <th class="text-end position-relative" data-tooltip="tickets purchased">
          <span class="d-sm-none">Tkt</span>
          <span class="d-none d-sm-inline">Tickets</span>
        </th>
        <th class="text-end d-none d-sm-table-cell d-md-none d-lg-table-cell position-relative" data-tooltip="tickets revoked">
          <span class="d-sm-none">Rev</span>
          <span class="d-none d-sm-inline">Revokes</span>
        </th>
        <th class="text-end position-relative" data-time-target="header" data-jstitle="Age" data-tooltip="block age">Age</th>
      </tr>
    </thead>
    <tbody data-controller="coin-accordion" data-home-latest-blocks-target="table">
      {{range .Blocks}}
      {{$blockHeight := .Height}}
      <tr
        class="block-row-expandable"
        data-coin-accordion-target="blockRow"
        data-block-id="{{.Height}}"
        data-height="{{.Height}}"
        data-link-class="fs18"
        data-action="click->coin-accordion#toggle"
      >
        <td class="text-start ps-1" data-type="height">
          <span class="chevron me-1"></span>
          <a href="/block/{{.Height}}" class="fs18">{{.Height}}</a>
        </td>
        <td class="text-end num" data-type="tx">{{.Transactions}}</td>
        <td class="text-end num" data-type="var-amount">{{.VARAmount}}</td>
        <td class="text-end num" data-type="ska-amount">{{if .SKAAmount}}{{.SKAAmount}}{{else}}—{{end}}</td>
        <td class="text-end num d-none d-sm-table-cell d-md-none d-lg-table-cell" data-type="size">{{.FormattedBytes}}</td>
        <td class="text-end num" data-type="votes">{{.Voters}}</td>
        <td class="text-end num" data-type="tickets">{{.FreshStake}}</td>
        <td class="text-end num d-none d-sm-table-cell d-md-none d-lg-table-cell" data-type="revocations">{{.Revocations}}</td>
        <td class="text-end num" data-type="age" data-time-target="age" data-age="{{.BlockTime.UNIX}}">
          {{.BlockTime.DatetimeWithoutTZ}}
        </td>
      </tr>
      <tr class="coin-sub-row" data-coin-accordion-target="subRow" data-block-id="{{$blockHeight}}">
        <td class="text-end ps-2 ps-sm-4" data-type="sub-label"><span class="coin-label coin-label--var">VAR</span></td>
        <td class="text-end num" data-type="tx">{{if .VARTxCount}}{{.VARTxCount}}{{else}}—{{end}}</td>
        <td class="text-end num" data-type="var-amount">{{.VARAmount}}</td>
        <td class="text-end">—</td>
        <td class="text-end num d-none d-sm-table-cell d-md-none d-lg-table-cell" data-type="size">{{.VARSize}}</td>
        <td class="text-end">—</td>
        <td class="text-end">—</td>
        <td class="text-end d-none d-sm-table-cell d-md-none d-lg-table-cell">—</td>
        <td class="text-end">—</td>
      </tr>
      {{range .SKASubRows}}
      <tr class="coin-sub-row" data-coin-accordion-target="subRow" data-block-id="{{$blockHeight}}">
        <td class="text-end ps-2 ps-sm-4" data-type="sub-label"><span class="coin-label coin-label--ska">{{.TokenType}}</span></td>
        <td class="text-end num" data-type="tx">{{.TxCount}}</td>
        <td class="text-end">—</td>
        <td class="text-end num" data-type="ska-amount">{{.Amount}}</td>
        <td class="text-end num d-none d-sm-table-cell d-md-none d-lg-table-cell" data-type="size">{{.Size}}</td>
        <td class="text-end">—</td>
        <td class="text-end">—</td>
        <td class="text-end d-none d-sm-table-cell d-md-none d-lg-table-cell">—</td>
        <td class="text-end">—</td>
      </tr>
      {{end}}
      {{end}}
    </tbody>
  </table>

  {{/* Templates for JS live-update cloning */}}
<template id="home-block-row-template">
  <tr
    class="block-row-expandable"
    data-coin-accordion-target="blockRow"
    data-block-id=""
    data-action="click->coin-accordion#toggle"
  >
    <td class="text-start ps-1" data-type="height">
      <span class="chevron me-1"></span>
      <a></a>
    </td>
    <td class="text-end num" data-type="tx"></td>
    <td class="text-end num" data-type="var-amount"></td>
    <td class="text-end num" data-type="ska-amount"></td>
    <td class="text-end num d-none d-sm-table-cell d-md-none d-lg-table-cell" data-type="size"></td>
    <td class="text-end num" data-type="votes"></td>
    <td class="text-end num" data-type="tickets"></td>
    <td class="text-end num d-none d-sm-table-cell d-md-none d-lg-table-cell" data-type="revocations"></td>
    <td class="text-end num" data-type="age" data-time-target="age"></td>
  </tr>
</template>

<template id="home-var-sub-row-template">
  <tr class="coin-sub-row" data-coin-accordion-target="subRow" data-block-id="">
    <td class="text-end ps-2 ps-sm-4" data-type="sub-label"><span class="coin-label coin-label--var">VAR</span></td>
    <td class="text-end num" data-type="tx"></td>
    <td class="text-end num" data-type="var-amount"></td>
    <td class="text-end">—</td>
    <td class="text-end num d-none d-sm-table-cell d-md-none d-lg-table-cell" data-type="size"></td>
    <td class="text-end">—</td>
    <td class="text-end">—</td>
    <td class="text-end d-none d-sm-table-cell d-md-none d-lg-table-cell">—</td>
    <td class="text-end">—</td>
  </tr>
</template>

<template id="home-ska-sub-row-template">
  <tr class="coin-sub-row" data-coin-accordion-target="subRow" data-block-id="">
    <td class="text-end ps-2 ps-sm-4" data-type="sub-label"><span class="coin-label coin-label--ska"></span></td>
    <td class="text-end num" data-type="tx"></td>
    <td class="text-end">—</td>
    <td class="text-end num" data-type="ska-amount"></td>
    <td class="text-end num d-none d-sm-table-cell d-md-none d-lg-table-cell" data-type="size"></td>
    <td class="text-end">—</td>
    <td class="text-end">—</td>
    <td class="text-end d-none d-sm-table-cell d-md-none d-lg-table-cell">—</td>
    <td class="text-end">—</td>
  </tr>
</template>
{{end}}
