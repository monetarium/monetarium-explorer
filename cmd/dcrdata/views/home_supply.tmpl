{{define "supply-card"}}
{{with .Info -}}
<div class="bg-white mb-1 p-2 px-3 mx-1 flex-grow-1">
  <div class="my-3 h4">
    <span class="monicon-coin-supply d-inline-block pe-2 h3"></span>
    Coin Supply
  </div>
  <div class="row mt-1">
    {{if .VARCoinSupply}}
    <div class="col-24 mb-3 mb-sm-2 mb-md-3 mb-lg-3">
      <div class="mono lh1rem fs14-decimal fs24 p03rem0 d-flex flex-wrap align-items-baseline">
        <span data-supply-target="varCirculating">
          {{template "decimalParts" (float64AsDecimalPartsNoTrailing (varAtomsToFloat64 .VARCoinSupply.Circulating) 8 true 2)}}
        </span>
        <a class="ps-1 unit lh15rem" href="/charts?chart=coin-supply/0">VAR</a>
      </div>
      <div class="fs12 lh1rem text-black-50" data-supply-target="varSupplyShare">
        {{printf "%.1f%%" (mulf (divideFloat (varAtomsToFloat64 .VARCoinSupply.Circulating) 54000000.0) 100.0)}} of ~54M
      </div>
    </div>
    {{end}}
    {{if .SKACoinSupply}}
    <div class="col-24 mb-3 mb-sm-2 mb-md-3 mb-lg-3">
      <div data-supply-target="skaCoinSupply" class="d-flex flex-column" style="gap:4px">
        {{range .SKACoinSupply}}
        <div>
          <div class="mono lh1rem fs14-decimal fs24 p03rem0 d-flex flex-wrap align-items-baseline">
            <span class="mono decimal-parts d-inline-block">{{template "decimalParts" (skaDecimalPartsNoTrailing .InCirculation true 2)}}</span>
            <a class="ps-1 unit lh15rem" href="/charts?chart=coin-supply/{{.CoinType}}">SKA{{.CoinType}}</a>
          </div>
          <div class="fs12 fs12-decimal lh1rem text-black-50 label-value-grid">
            <span class="text-start">Issued:</span>
            <span class="text-start">
              <span class="mono decimal-parts d-inline-block">{{template "decimalParts" (skaDecimalPartsNoTrailing .TotalIssued true 2)}}</span>
            </span>
            <span class="text-start">Burned:</span>
            <span class="text-start">
              <span class="mono decimal-parts d-inline-block">{{template "decimalParts" (skaDecimalPartsNoTrailing .TotalBurned true 2)}}</span>
            </span>
          </div>
        </div>
        {{end}}
      </div>
    </div>
    {{end}}
  </div>
</div>

{{/* Template for JS live-update cloning — one SKA supply block */}}
<template id="ska-supply-block-template">
  <div>
    <div class="mono lh1rem fs14-decimal fs24 p03rem0 d-flex flex-wrap align-items-baseline">
      <span class="mono decimal-parts d-inline-block in-circulation"></span>
      <a class="ps-1 unit lh15rem symbol-link"><span class="symbol"></span></a>
    </div>
    <div class="fs12 fs12-decimal lh1rem text-black-50 label-value-grid">
      <span class="text-start">Issued:</span>
      <span class="text-start"><span class="mono decimal-parts d-inline-block issued"></span></span>
      <span class="text-start">Burned:</span>
      <span class="text-start"><span class="mono decimal-parts d-inline-block burned"></span></span>
    </div>
  </div>
</template>

{{- end}}
{{end}}
