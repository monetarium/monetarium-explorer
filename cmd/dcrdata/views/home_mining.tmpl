{{define "mining-card"}}
{{- $page := . -}}
{{- $conv := $page.Conversions -}}
{{with $page.Info -}}
<div class="bg-white mb-1 py-2 px-3 mx-1 my-0">
    <div class="my-3 h4">
        <span class="monicon-pickaxe d-inline-block pe-2 h3"></span>
        <span>Mining</span>
    </div>
    <div class="row mt-1">
        <div class="col-12 mb-3 mb-sm-2 mb-md-3 mb-lg-3">
            <div class="fs13 text-secondary">
                <a class="no-underline" href="/charts?chart=pow-difficulty">Difficulty</a>
            </div>
            <div class="mono lh1rem p03rem0 fs14-decimal fs24 p03rem0 d-flex align-items-baseline">
                <span data-mining-target="difficulty">{{threeSigFigs .Difficulty}}</span>
            </div>
        </div>
        <div class="col-12 mb-3 mb-sm-2 mb-md-3 mb-lg-3">
            <div class="fs13 text-secondary"><a href="/charts?chart=hashrate">Hashrate</a></div>
            <div class="mono lh1rem pt-1 pb-1 fs14-decimal fs24 d-flex align-items-baseline">
                <span data-mining-target="hashrate">{{template "decimalParts" (float64AsDecimalParts .HashRate 8 true 2)}}</span>
                <span class="ps-1 unit lh15rem">Ph/s</span>
            </div>
            <div class="fs12 text-black-50 lh1rem text-black-50">
                <span data-mining-target="hashrateDelta">{{template "fmtPercentage" .HashRateChangeMonth}}</span> in past 30 days
            </div>
        </div>
        {{/* Row 2 left: PoW VAR Reward */}}
        <div class="col-12 mb-3 mb-sm-2 mb-md-3 mb-lg-3">
            <div class="fs13 text-secondary">PoW VAR Reward (most&nbsp;recent)</div>
            <div class="mono lh1rem p03rem0 fs14-decimal fs24 p03rem0 d-flex align-items-baseline">
                <span data-mining-target="bsubsidyPow">{{template "decimalParts" (float64AsDecimalParts (toFloat64Amount .LBlockTotalAtoms) 8 true 2)}}</span>
                <span class="ps-1 unit lh15rem">VAR</span>
            </div>
            <div class="fs12 fs12-decimal lh1rem text-black-50 label-value-grid">
                <span class="text-start">Subsidy:</span>
                <span class="text-start">
                    <span class="mono" data-mining-target="powSubsidy">{{template "decimalParts" (float64AsDecimalParts (toFloat64Amount .NBlockSubsidy.PoW) 8 false 2)}}</span>
                </span>
                <span class="text-start">Fee:</span>
                <span class="text-start">
                    <span class="mono" data-mining-target="powFee">{{template "decimalParts" (float64AsDecimalParts (toFloat64Amount .MiningFeeAtoms) 8 false 2)}}</span>
                </span>
            </div>
        </div>
        {{/* Row 2 right: Next Block VAR Subsidy Reduction (swapped from below) */}}
        <div class="col-12 mb-3 mb-sm-2 mb-md-3 mb-lg-3">
            <div class="fs13 text-secondary lh1rem">Next Block VAR Subsidy Reduction</div>
            <div class="progress mt-1 mb-1">
                <div
                    class="progress-bar rounded"
                    data-mining-target="powBar"
                    role="progressbar"
                    style="width: {{rewardAdjustmentProgress .IdxInRewardWindow}}%;"
                    aria-valuenow="{{.IdxInRewardWindow}}"
                    aria-valuemin="0"
                    aria-valuemax="{{.Params.RewardWindowSize}}"
                >
                    <span
                        id="powreward"
                        class="nowrap ps-1"
                    >
                        block <span data-mining-target="rewardIdx" >{{.IdxInRewardWindow}}</span> of {{.Params.RewardWindowSize}}
                    </span>
                </div>
            </div>
            <div class="fs12 lh1rem">
                <span class="text-black-50">
                    {{remaining .IdxInRewardWindow .Params.RewardWindowSize .Params.BlockTime}}
                </span>
            </div>
        </div>
        {{/* Row 3: PoW SKA Fee Reward (moved below, grows as new SKA types are emitted) */}}
        <div class="col-24 mb-3 mb-sm-2 mb-md-3 mb-lg-3">
            <div class="fs13 text-secondary">PoW SKA Fee Reward (most&nbsp;recent)</div>
            <div data-mining-target="powSkaRewards" class="d-flex flex-column" style="gap:4px">
            {{if .PoWSKARewards}}
            {{range .PoWSKARewards}}
            <a class="text-decoration-none"{{if .BlockHeight}} href="/block/{{.BlockHeight}}"{{end}}>
                <div class="mono lh1rem p03rem0 fs14-decimal fs24 p03rem0 d-flex align-items-baseline">
                    <span>{{template "decimalParts" (skaDecimalParts .Amount true 2)}}</span>
                    <span class="ps-1 unit lh15rem">{{.Symbol}}</span>
                </div>
            </a>
            {{end}}
            {{else}}
                <div class="fs12 lh1rem text-black-50">No SKA rewards available</div>
            {{end}}
            </div>
        </div>
        {{/* Templates for JS live-update cloning */}}
        <template id="pow-ska-reward-template">
            <a class="text-decoration-none" data-block-height>
            <div class="mono lh1rem p03rem0 fs14-decimal fs24 p03rem0 d-flex align-items-baseline">
                <div class="decimal-parts d-inline-block">
                    <span class="int"></span>
                </div>
                <span class="ps-1 unit lh15rem"><span class="symbol"></span></span>
            </div>
            </a>
        </template>
        <template id="pow-ska-empty-template">
            <div class="fs12 lh1rem text-black-50">No SKA rewards available</div>
        </template>
    </div>
</div> <!-- end mining card -->
{{- end}}
{{end}}
