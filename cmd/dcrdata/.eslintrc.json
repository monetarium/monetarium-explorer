{
  "extends": ["standard", "prettier"],
  "parser": "@babel/eslint-parser",
  "rules": {
    "no-console": ["off"],
    "no-alert": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-var": "error",
    "array-callback-return": "off",
    "object-shorthand": ["error", "consistent"]
  }
}
